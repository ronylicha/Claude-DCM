# DCM Docker Configuration
# Copy to .env and customize ports to avoid conflicts

# Database
DB_NAME=claude_context
DB_USER=dcm
DB_PASSWORD=dcm_secret
DB_PORT=5433

# Redis
REDIS_PORT=6380

# API
API_PORT=3847
WS_PORT=3849
DASHBOARD_PORT=3848

# External access (for dashboard to reach API)
DCM_HOST=127.0.0.1

# WebSocket auth
WS_AUTH_SECRET=dcm_ws_secret
